# ============================================
# IndAI — Environment Configuration
# ============================================
# Copy this file to .env and fill in values

# Flask
FLASK_ENV=development
SECRET_KEY=your-secret-key-change-this-in-production

# GitHub Integration
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Redis for Task Queuing
REDIS_URL=redis://localhost:6379/0

# Facebook OAuth
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret
FACEBOOK_REDIRECT_URI=https://indai-webapp-d1857db81932.herokuapp.com/api/v1/process/auth/facebook/callback

# Superadmin Definition (irrevocable access)
SUPERADMIN_EMAIL=your-email@example.com

# Google OAuth 2.0
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://indai-webapp-d1857db81932.herokuapp.com/api/v1/process/auth/google/callback

# Database
# Development (SQLite)
DATABASE_URL=sqlite:///indai.db
# Production (PostgreSQL on Render)
# DATABASE_URL=postgresql://user:pass@host:5432/indai

# Frontend URL (for CORS + OAuth redirect)
FRONTEND_URL=https://ind-ai-five.vercel.app

# Server
PORT=5000

# AI — Gemini (Optional — agent widget works without it)
GEMINI_API_KEY=your-gemini-api-key

# Tesseract OCR path (optional — for image code extraction)
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# Resend (Email OTP Authentication)
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=IndAI <noreply@yourdomain.com>
